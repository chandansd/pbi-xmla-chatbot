# ── OpenAI (use one of the two options below) ──────────────────────────────────

# Option A: OpenAI directly
OPENAI_API_KEY=sk-proj-...

# Option B: Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=<your-azure-key>
# AZURE_OPENAI_API_VERSION=2024-06-01
# MODEL_NAME=<your-deployment-name>

# ── Power BI XMLA (Azure AD Service Principal) ─────────────────────────────────
TENANT_ID=<your-azure-tenant-id>
CLIENT_ID=<your-app-registration-client-id>
CLIENT_SECRET=<your-app-registration-client-secret>

# ── Power BI Workspace & Dataset ───────────────────────────────────────────────
WORKSPACE=<your-power-bi-workspace-name>
WORKSPACE_ID=<your-workspace-id>
DATASET=<your-dataset-name>
DATASET_ID=<your-dataset-id>

# ── Internal (leave as-is unless you change the port) ──────────────────────────
XMLA_API=http://localhost:5000/run-dax
